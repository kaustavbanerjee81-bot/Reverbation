# CELL 6 — MAIN LOOP: for each quant config → build features
# → train all 5 models → record train/val/test accuracy
# ════════════════════════════════════════════════════════

def build_split_features(split_name, scheme, bit_depth):
    """Quantize cached raw signals for this split/config, extract features."""
    X, y = [], []
    for item in raw_cache[split_name]:
        if bit_depth is None:
            clean_q  = quantize(item['clean_raw'],  scheme=scheme)
            reverb_q = quantize(item['reverb_raw'], scheme=scheme)
        else:
            clean_q  = quantize(item['clean_raw'],  scheme=scheme, bit_depth=bit_depth)
            reverb_q = quantize(item['reverb_raw'], scheme=scheme, bit_depth=bit_depth)
        X.extend([compute_features(clean_q), compute_features(reverb_q)])
        y.extend([0, 1])
    return np.array(X, dtype=np.float64), np.array(y, dtype=np.int32)

