# NEW CELL A4 — ZCR + mean ACR(1-3) + Spectral Centroid +
#               Spectral Rolloff(85%) + Spectral Entropy + Spectral Flatness
# (Paste as a NEW cell — reuses raw_cache already in memory,
#  no need to rerun Cell 3C reverb simulation)
#
# Feature vector (6 dims):
#   [0] ZCR
#   [1] mean_ACR(1-3)        — mean normalized autocorrelation, lags 1,2,3
#   [2] spectral_centroid_Hz — weighted mean freq of magnitude spectrum
#   [3] spectral_rolloff_Hz  — freq below which 85% of spectral energy sits
#   [4] spectral_entropy     — Shannon entropy of the (normalized) power
#                              spectrum, itself normalized to [0,1] by
#                              log2(N_bins). High = noise-like/flat energy
#                              spread across freq (reverb tends to raise
#                              this); low = concentrated/tonal energy.
#   [5] spectral_flatness    — geometric mean / arithmetic mean of the
#                              power spectrum ("Wiener entropy"), in (0,1].
#                              ~1 = white-noise-like (flat spectrum);
#                              ~0 = tonal/peaky spectrum.
#
# All spectral features computed on the FULL signal's FFT (not
# frame-by-frame), consistent with how ZCR/ACR are computed
# elsewhere in this pipeline.
# ════════════════════════════════════════════════════════

ROLLOFF_PERCENT = 0.85   # fraction of total spectral energy — EDIT if needed
N_SHORT_LAGS    = 3      # ACR lags: 1, 2, 3
SPEC_EPS        = 1e-12  # numerical floor to avoid log(0)

def compute_zcr(signal):
    sign = np.where(signal >= 0, 1, -1)
    return np.sum(np.abs(sign[1:] - sign[:-1])) / 2 / (len(signal) - 1)

def _normalized_autocorr_at_lags(signal, lags):
    """R(k) = sum(x[t]*x[t+k]) / sum(x[t]^2), for each k in lags."""
    signal = np.asarray(signal, dtype=np.float64)
    energy = np.sum(signal ** 2)
    out = np.zeros(len(lags), dtype=np.float64)
    if energy == 0.0:
        return out
    for i, k in enumerate(lags):
        if k >= len(signal):
            out[i] = 0.0
            continue
        out[i] = np.sum(signal[:-k] * signal[k:]) / energy
    return out

def _magnitude_spectrum(signal):
    signal = np.asarray(signal, dtype=np.float64)
    return np.abs(np.fft.rfft(signal))

def compute_spectral_centroid(signal, sr=SR):
    """Weighted mean frequency, weighted by magnitude spectrum."""
    mag   = _magnitude_spectrum(signal)
    freqs = np.fft.rfftfreq(len(signal), d=1.0/sr)
    total = np.sum(mag)
    if total == 0.0:
        return 0.0
    return float(np.sum(freqs * mag) / total)

def compute_spectral_rolloff(signal, sr=SR, roll_percent=ROLLOFF_PERCENT):
    """Frequency below which `roll_percent` of total spectral energy sits."""
    mag   = _magnitude_spectrum(signal)
    freqs = np.fft.rfftfreq(len(signal), d=1.0/sr)
    total = np.sum(mag)
    if total == 0.0:
        return 0.0
    cumulative = np.cumsum(mag)
    threshold  = roll_percent * total
    idx        = np.searchsorted(cumulative, threshold)
    idx        = min(idx, len(freqs) - 1)
    return float(freqs[idx])

def compute_spectral_entropy(signal):
    """
    Shannon entropy of the normalized power spectrum, scaled to [0,1]
    by dividing by log2(number of frequency bins with nonzero power).
    """
    mag   = _magnitude_spectrum(signal)
    power = mag ** 2
    total = np.sum(power)
    if total == 0.0:
        return 0.0
    psd = power / total
    psd = psd[psd > 0]
    if len(psd) <= 1:
        return 0.0
    entropy = -np.sum(psd * np.log2(psd))
    return float(entropy / np.log2(len(psd)))

def compute_spectral_flatness(signal):
    """
    Geometric mean / arithmetic mean of the power spectrum ("Wiener entropy").
    ~1 = flat/noise-like spectrum, ~0 = peaky/tonal spectrum.
    """
    mag   = _magnitude_spectrum(signal)
    power = mag ** 2 + SPEC_EPS
    geo_mean   = np.exp(np.mean(np.log(power)))
    arith_mean = np.mean(power)
    if arith_mean == 0.0:
        return 0.0
    return float(geo_mean / arith_mean)

def compute_features_full6(signal):
    """
    Returns 6-dim feature vector:
      [ZCR, mean_ACR(1..3), spectral_centroid_Hz, spectral_rolloff_Hz,
       spectral_entropy, spectral_flatness]
    """
    zcr = compute_zcr(signal)

    short_lags = list(range(1, N_SHORT_LAGS + 1))  # [1, 2, 3]
    acr_vals   = _normalized_autocorr_at_lags(signal, short_lags)
    mean_acr   = np.mean(acr_vals)

    centroid = compute_spectral_centroid(signal, sr=SR)
    rolloff  = compute_spectral_rolloff(signal, sr=SR, roll_percent=ROLLOFF_PERCENT)
    entropy  = compute_spectral_entropy(signal)
    flatness = compute_spectral_flatness(signal)

    return np.array([zcr, mean_acr, centroid, rolloff, entropy, flatness])

N_FEATURES_FULL6 = 6
FEATURE_NAMES_FULL6 = ['ZCR', 'mean_ACR(1-3)', 'spectral_centroid_Hz',
                        'spectral_rolloff_Hz', 'spectral_entropy', 'spectral_flatness']

print(f"✅ Feature function ready — {N_FEATURES_FULL6} dims: {FEATURE_NAMES_FULL6}")
print(f"   ACR lags: 1, 2, 3 (samples)")
print(f"   Spectral rolloff threshold: {ROLLOFF_PERCENT*100:.0f}% of total energy")


# ════════════════════════════════════════════════════════
# NEW CELL B4 — BUILD FEATURES FROM EXISTING raw_cache
# Reuses: raw_cache, quantize, QUANT_CONFIGS, make_models, MODEL_NAMES, SEED
