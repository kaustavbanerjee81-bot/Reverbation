for label, scheme, bit_depth in QUANT_CONFIGS:
    print(f"\n▶ Config: {label}  (scheme={scheme}, bit_depth={bit_depth})")

    X_train, y_train = build_split_features('train', scheme, bit_depth)
    X_val,   y_val   = build_split_features('val',   scheme, bit_depth)
    X_test,  y_test  = build_split_features('test',  scheme, bit_depth)

    # shuffle train only
    rng_tr = np.random.default_rng(seed=SEED)
    idx = rng_tr.permutation(len(y_train))
    X_train, y_train = X_train[idx], y_train[idx]

    # scale — fit on train only
    scaler = StandardScaler()
    X_train_sc = scaler.fit_transform(X_train)
    X_val_sc   = scaler.transform(X_val)
    X_test_sc  = scaler.transform(X_test)

    results[label] = {}
    models = make_models()
    for model_name, model in models.items():
        model.fit(X_train_sc, y_train)
        acc_train = accuracy_score(y_train, model.predict(X_train_sc))
        acc_val   = accuracy_score(y_val,   model.predict(X_val_sc))
        acc_test  = accuracy_score(y_test,  model.predict(X_test_sc))
        results[label][model_name] = dict(train=acc_train, val=acc_val, test=acc_test)
        print(f"    {model_name:18s}  Train={acc_train*100:5.1f}%  "
              f"Val={acc_val*100:5.1f}%  Test={acc_test*100:5.1f}%")

