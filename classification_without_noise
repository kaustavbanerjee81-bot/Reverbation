# NEW CELL A3 — ZCR + mean ACR(1-3) + spectral centroid + spectral rolloff
# (Paste as a NEW cell — reuses raw_cache already in memory,
#  no need to rerun Cell 3C reverb simulation)
#
# Feature vector (4 dims):
#   [0] ZCR
#   [1] mean short-term autocorrelation, lags 1,2,3 (sample-level)
#   [2] Spectral centroid (Hz)   — "center of mass" of the magnitude spectrum
#   [3] Spectral rolloff (Hz)    — freq below which 85% of spectral energy sits
#
# Both spectral features are computed on the FULL signal's FFT
# (not frame-by-frame), to stay consistent with how ZCR/ACR are
# computed over the whole utterance elsewhere in this pipeline.
# Edit ROLLOFF_PERCENT below if you want a different threshold
# (85% is the standard default used in most audio libraries).
# ════════════════════════════════════════════════════════

ROLLOFF_PERCENT = 0.85   # fraction of total spectral energy — EDIT if needed
N_SHORT_LAGS    = 3      # ACR lags: 1, 2, 3

def compute_zcr(signal):
    sign = np.where(signal >= 0, 1, -1)
    return np.sum(np.abs(sign[1:] - sign[:-1])) / 2 / (len(signal) - 1)

def _normalized_autocorr_at_lags(signal, lags):
    """R(k) = sum(x[t]*x[t+k]) / sum(x[t]^2), for each k in lags."""
    signal = np.asarray(signal, dtype=np.float64)
    energy = np.sum(signal ** 2)
    out = np.zeros(len(lags), dtype=np.float64)
    if energy == 0.0:
        return out
    for i, k in enumerate(lags):
        if k >= len(signal):
            out[i] = 0.0
            continue
        out[i] = np.sum(signal[:-k] * signal[k:]) / energy
    return out

def compute_spectral_centroid(signal, sr=SR):
    """
    Spectral centroid = weighted mean frequency, weighted by magnitude spectrum.
    Higher = more high-frequency energy ("brighter" sound).
    """
    signal = np.asarray(signal, dtype=np.float64)
    mag    = np.abs(np.fft.rfft(signal))
    freqs  = np.fft.rfftfreq(len(signal), d=1.0/sr)
    total  = np.sum(mag)
    if total == 0.0:
        return 0.0
    return float(np.sum(freqs * mag) / total)

def compute_spectral_rolloff(signal, sr=SR, roll_percent=ROLLOFF_PERCENT):
    """
    Spectral rolloff = frequency below which `roll_percent` of the total
    spectral energy (magnitude) is contained.
    """
    signal = np.asarray(signal, dtype=np.float64)
    mag    = np.abs(np.fft.rfft(signal))
    freqs  = np.fft.rfftfreq(len(signal), d=1.0/sr)
    total  = np.sum(mag)
    if total == 0.0:
        return 0.0
    cumulative = np.cumsum(mag)
    threshold  = roll_percent * total
    idx        = np.searchsorted(cumulative, threshold)
    idx        = min(idx, len(freqs) - 1)
    return float(freqs[idx])

def compute_features_zcr_acr_spectral(signal):
    """
    Returns 4-dim feature vector:
      [ZCR, mean_ACR(1..3), spectral_centroid_Hz, spectral_rolloff_Hz]
    """
    zcr = compute_zcr(signal)

    short_lags = list(range(1, N_SHORT_LAGS + 1))  # [1, 2, 3]
    acr_vals   = _normalized_autocorr_at_lags(signal, short_lags)
    mean_acr   = np.mean(acr_vals)

    centroid = compute_spectral_centroid(signal, sr=SR)
    rolloff  = compute_spectral_rolloff(signal, sr=SR, roll_percent=ROLLOFF_PERCENT)

    return np.array([zcr, mean_acr, centroid, rolloff])

