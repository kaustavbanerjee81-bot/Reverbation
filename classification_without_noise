# CELL 4 — FEATURE EXTRACTION FUNCTIONS  (ZCR + Autocorr)
# ════════════════════════════════════════════════════════

N_LAGS     = 3
N_FEATURES = 1 + N_LAGS

def compute_zcr(signal):
    sign = np.where(signal >= 0, 1, -1)
    return np.sum(np.abs(sign[1:] - sign[:-1])) / 2 / (len(signal) - 1)

def compute_normalized_autocorr(signal, n_lags=N_LAGS):
    signal = np.asarray(signal, dtype=np.float64)
    energy = np.sum(signal ** 2)
    if energy == 0.0:
        return np.zeros(n_lags, dtype=np.float64)
    ac = np.zeros(n_lags, dtype=np.float64)
    for k in range(1, n_lags + 1):
        ac[k - 1] = np.sum(signal[:-k] * signal[k:]) / energy
    return ac

def compute_features(signal):
    zcr = compute_zcr(signal)
    ac  = compute_normalized_autocorr(signal, N_LAGS)
    return np.concatenate([[zcr], ac])

print(f"✅ Feature functions ready — {N_FEATURES} dims "
      f"(ZCR + R(1)..R({N_LAGS}))")


