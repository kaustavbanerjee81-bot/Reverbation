# NEW CELL A2 — ZCR + mean ACR(1-3) + mean LTTC(1-3) FEATURES
# (Paste as a NEW cell — reuses raw_cache already in memory,
#  no need to rerun Cell 3C reverb simulation)
#
# Feature vector (3 dims):
#   [0] ZCR
#   [1] mean short-term autocorrelation, lags 1,2,3 (sample-level)
#   [2] mean long-term temporal correlation, "lags" 1,2,3
#       — each long-term lag = k * LTTC_LAG_STEP samples
#       — LTTC_LAG_STEP defaults to 80 samples (~5 ms @ 16kHz),
#         inside the typical speech pitch-period range.
#         EDIT THIS if you meant a different long-term window.
# ════════════════════════════════════════════════════════

LTTC_LAG_STEP = 80   # samples per long-term "lag" step (~5ms @ 16kHz) — EDIT if needed
N_SHORT_LAGS  = 3    # ACR lags: 1, 2, 3
N_LONG_LAGS   = 3    # LTTC lags: LTTC_LAG_STEP*1, *2, *3

def compute_zcr(signal):
    sign = np.where(signal >= 0, 1, -1)
    return np.sum(np.abs(sign[1:] - sign[:-1])) / 2 / (len(signal) - 1)

def _normalized_autocorr_at_lags(signal, lags):
    """R(k) = sum(x[t]*x[t+k]) / sum(x[t]^2), for each k in lags."""
    signal = np.asarray(signal, dtype=np.float64)
    energy = np.sum(signal ** 2)
    out = np.zeros(len(lags), dtype=np.float64)
    if energy == 0.0:
        return out
    for i, k in enumerate(lags):
        if k >= len(signal):
            out[i] = 0.0
            continue
        out[i] = np.sum(signal[:-k] * signal[k:]) / energy
    return out

def compute_features_zcr_acr_lttc(signal):
    """
    Returns 3-dim feature vector:
      [ZCR, mean_ACR(1..3), mean_LTTC(1..3)]
    """
    zcr = compute_zcr(signal)

    short_lags = list(range(1, N_SHORT_LAGS + 1))               # [1, 2, 3]
    long_lags  = [LTTC_LAG_STEP * k for k in range(1, N_LONG_LAGS + 1)]  # [80, 160, 240]

    acr_vals  = _normalized_autocorr_at_lags(signal, short_lags)
    lttc_vals = _normalized_autocorr_at_lags(signal, long_lags)

    mean_acr  = np.mean(acr_vals)
    mean_lttc = np.mean(lttc_vals)

    return np.array([zcr, mean_acr, mean_lttc])

