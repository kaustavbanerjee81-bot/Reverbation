# ════════════════════════════════════════════════════════
N_AC_LAGS        = 3
N_FEATURES       = 6
ROLLOFF_PERCENT  = 0.85
LOG_EPS          = 1e-12

def compute_zcr(signal):
    signs = np.sign(signal); signs[signs == 0] = 1
    return float(np.sum(np.diff(signs) != 0) / (len(signal) - 1))

def compute_mean_autocorr(signal, n_lags=N_AC_LAGS):
    signal = np.asarray(signal, dtype=np.float64)
    energy = np.sum(signal ** 2)
    if energy == 0.0: return 0.0
    ac = np.array([np.sum(signal[:-k] * signal[k:]) / energy
                   for k in range(1, n_lags + 1)])
    return float(np.mean(ac))

def compute_spectral_centroid(signal, sr):
    mag   = np.abs(np.fft.rfft(signal.astype(np.float64)))
    total = np.sum(mag)
    if total == 0.0: return 0.0
    freqs = np.fft.rfftfreq(len(signal), d=1.0/sr)
    return float(np.sum(freqs * mag) / total)

def compute_spectral_rolloff(signal, sr, roll_percent=ROLLOFF_PERCENT):
    mag   = np.abs(np.fft.rfft(signal.astype(np.float64)))
    total = np.sum(mag)
    if total == 0.0: return 0.0
    freqs   = np.fft.rfftfreq(len(signal), d=1.0/sr)
    cum_mag = np.cumsum(mag)
    idx     = min(np.searchsorted(cum_mag, roll_percent * total), len(freqs) - 1)
    return float(freqs[idx])

def compute_spectral_entropy(signal):
    power = np.abs(np.fft.rfft(signal.astype(np.float64))) ** 2
    total = np.sum(power)
    if total == 0.0: return 0.0
    P = power / total
    return float(-np.sum(P * np.log2(P + LOG_EPS)) / np.log2(len(P)))

def compute_spectral_flatness(signal):
    power = np.abs(np.fft.rfft(signal.astype(np.float64))) ** 2
    if np.sum(power) == 0.0: return 0.0
    return float(np.exp(np.mean(np.log(power + LOG_EPS))) /
                 (np.mean(power) + LOG_EPS))

def compute_features(signal_q, sr):
    return np.array([
        compute_zcr(signal_q),
        compute_mean_autocorr(signal_q, N_AC_LAGS),
        compute_spectral_centroid(signal_q, sr),
        compute_spectral_rolloff(signal_q, sr, ROLLOFF_PERCENT),
        compute_spectral_entropy(signal_q),
        compute_spectral_flatness(signal_q),
    ], dtype=np.float64)

def process_feature_split(npy_dir, split_name):
    all_files   = sorted(os.listdir(npy_dir))
    clean_files = [f for f in all_files if f.endswith('_clean_q.npy')]
    reverb_files= [f for f in all_files if f.endswith('_reverb_q.npy')]
    assert len(clean_files) == len(reverb_files)

    print(f"\n  {split_name.upper()} — {len(clean_files)} pairs")
    X, y = [], []
    for cf, rf in zip(clean_files, reverb_files):
        cq = np.load(os.path.join(npy_dir, cf))
        rq = np.load(os.path.join(npy_dir, rf))
        fc = compute_features(cq, SR)
        fr = compute_features(rq, SR)
        X.extend([fc, fr]); y.extend([0, 1])
        print(f"  {cf[:30]:30s}  "
              f"ZCR={fc[0]:.4f}/{fr[0]:.4f}  "
              f"mAC={fc[1]:.4f}/{fr[1]:.4f}  "
              f"SC={fc[2]:.1f}/{fr[2]:.1f}Hz")
    return np.array(X, dtype=np.float64), np.array(y, dtype=np.int32)

