              f"SE={feat_c[4]:.4f}/{feat_r[4]:.4f}  "
              f"SF={feat_c[5]:.4f}/{feat_r[5]:.4f}")

    X = np.array(X, dtype=np.float64)
    y = np.array(y, dtype=np.int32)

    feat_names = ['ZCR', 'mean_AC', 'Spec_Centroid(Hz)', 'Spec_Rolloff(Hz)',
