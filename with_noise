# CELL 3B — DEREVERBERATION HELPER
# ════════════════════════════════════════════════════════
SR          = 16000
MASTER_SEED = 42

derev_params = {
    "t60_range"          : [0.1, 2.5],
    "dim_range"          : [5, 15, 5, 15, 2, 6],
    "min_distance_to_wall": 1.0
}

def apply_dereverberation(speech, seed):
    np.random.seed(seed)

    t60 = np.random.uniform(*derev_params["t60_range"])
    room_dim = np.array([
        np.random.uniform(derev_params["dim_range"][2*n],
                          derev_params["dim_range"][2*n+1])
        for n in range(3)
    ])
    center_mic = np.array([
        np.random.uniform(derev_params["min_distance_to_wall"],
                          room_dim[n] - derev_params["min_distance_to_wall"])
        for n in range(3)
    ])

    for _ in range(100):
        source_pos = np.array([
            np.random.uniform(derev_params["min_distance_to_wall"],
                              room_dim[n] - derev_params["min_distance_to_wall"])
            for n in range(3)
        ])
        if np.linalg.norm(source_pos - center_mic) >= 0.5:
            break

    n_mics  = np.random.randint(1, 5)
    radius  = np.random.uniform(0.05, 0.5)
    mic_array_2d = pra.beamforming.circular_2D_array(
        center_mic[:-1], n_mics, phi0=0, radius=radius)
    mic_array = np.pad(mic_array_2d, ((0,1),(0,0)),
                       mode='constant', constant_values=center_mic[-1])

    e_abs, max_order = pra.inverse_sabine(t60, room_dim)
    use_ray = np.random.rand() > 0.5

    rev_room = pra.ShoeBox(room_dim, fs=SR,
                           materials=pra.Material(e_abs),
                           max_order=min(3, max_order),
                           ray_tracing=use_ray)
    if use_ray:
        rev_room.set_ray_tracing()
    rev_room.add_microphone_array(mic_array)
    rev_room.add_source(source_pos, signal=speech)
    rev_room.compute_rir(); rev_room.simulate()

    t60_real     = np.mean(rev_room.measure_rt60()).squeeze()
    lossy_speech = np.squeeze(np.array(rev_room.mic_array.signals))
    if lossy_speech.ndim > 1:
        lossy_speech = lossy_speech[0]

    dry_room = pra.ShoeBox(room_dim, fs=SR,
                           materials=pra.Material(0.99),
                           max_order=0)
    dry_room.add_microphone_array(mic_array)
    dry_room.add_source(source_pos, signal=speech)
    dry_room.compute_rir(); dry_room.simulate()

    speech_out = np.squeeze(np.array(dry_room.mic_array.signals))
    if speech_out.ndim > 1:
        speech_out = speech_out[0]

    # Internal low-level noise (very high SNR, not the additive noise stage)
    snr_db      = np.random.uniform(30, 60)
    noise_power = (1/speech_out.shape[0]) * np.sum(speech_out**2) \
                  * np.power(10, -snr_db/10)
    noise_dur   = np.random.uniform(0.2, 1.0)
    noise_sig   = np.random.randn(int(noise_dur * SR)) * np.sqrt(noise_power)
    speech_out  = np.concatenate([speech_out, noise_sig])

    min_len = min(lossy_speech.shape[0], speech_out.shape[0])
    return speech_out[:min_len], lossy_speech[:min_len], t60_real

