quant_code = '''
import numpy as np

MU = 255
A  = 87.6

def normalise(x):
    x    = np.asarray(x, dtype=np.float64)
    peak = np.max(np.abs(x))
    return x if peak == 0.0 else x / peak

def mu_law_compress(x, mu=MU):
    x = np.clip(x, -1.0, 1.0)
    return np.sign(x) * np.log1p(mu * np.abs(x)) / np.log1p(mu)

def a_law_compress(x, a=A):
    x   = np.clip(x, -1.0, 1.0)
    ax  = np.abs(x)
    lna = np.log(a)
    out = np.where(ax <= 1.0/a,
                   a * ax / (1.0 + lna),
                   (1.0 + np.log(a * ax + 1e-12)) / (1.0 + lna))
    return np.sign(x) * np.clip(out, 0.0, 1.0)

def _uniform_midtread(x, bit_depth):
    delta = 2.0 ** (1 - bit_depth)
    x_q   = delta * np.round(x / delta)
    return np.clip(x_q, -(1.0 - delta/2.0), 1.0 - delta/2.0)

def _log2_quantize(x, bit_depth):
    x     = np.clip(x, -1.0, 1.0)
    sign  = np.sign(x)
    mag   = np.abs(x)
    eps   = 2.0 ** -(2 ** (bit_depth - 1))
    log_mag  = np.log2(np.where(mag < eps, eps, mag))
    log_min  = -float(2 ** (bit_depth - 1))
    log_norm = np.clip(log_mag / (-log_min), 0.0, 1.0)
    levels   = 2 ** (bit_depth - 1)
    log_q    = np.round(log_norm * (levels - 1)) / (levels - 1)
    mag_q    = 2.0 ** (log_q * log_min)
    return np.where(sign == 0, 0.0, sign * mag_q)

def quantize(x, scheme, bit_depth=1, mu=MU, a=A):
    x = np.asarray(x, dtype=np.float64)
    x = np.clip(x, -1.0, 1.0)
    if scheme == 1: return np.where(x > 0, 1.0, -1.0)
    if scheme == 6: return x.copy()
    if scheme == 2: return _uniform_midtread(x, bit_depth)
    if scheme == 3: return _uniform_midtread(mu_law_compress(x, mu), bit_depth)
    if scheme == 4: return _uniform_midtread(a_law_compress(x, a), bit_depth)
    if scheme == 5: return _log2_quantize(x, bit_depth)
    raise ValueError(f"Unknown scheme: {scheme}")
'''
with open('/content/speech_quantization.py', 'w') as f:
    f.write(quant_code)

