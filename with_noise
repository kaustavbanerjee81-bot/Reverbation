# CELL 4B — STEP 4: COMPUTE 6-DIM FEATURE VECTOR
#
# ALL SIX FEATURES COMPUTED ON 1-BIT QUANTIZED SIGNAL
#
# Feature vector — 6 dimensions:
#
#   Index  0  :  ZCR
#   Index  1  :  mean_AC       = mean( R(1), R(2), ..., R(4) )
#   Index  2  :  spectral_centroid
#   Index  3  :  spectral_rolloff (85%)
#   Index  4  :  spectral_entropy
#   Index  5  :  spectral_flatness
#
# ── ZCR ──────────────────────────────────────────────
#   ZCR = number_of_sign_changes / (T - 1)
#   sign(0) treated as +1
#
# ── Autocorrelation ──────────────────────────────────
#   R(k) = Σ x(t)*x(t+k) / Σ x(t)^2     k = 1..4
#   mean_AC = mean( R(1)..R(4) )  →  1 scalar
#
# ── Spectral Centroid ─────────────────────────────────
#   Centroid = Σ_k [ f_k * |X(k)| ] / Σ_k |X(k)|
#   f_k = k * sr / N   (frequency bin centres)
#   Computed via np.fft.rfft on 1-bit quantized signal
#
# ── Spectral Roll-off (85%) ───────────────────────────
#   Frequency below which 85% of cumulative spectral
#   magnitude is contained.
#   Rolloff = f_k  where  Σ_{j<=k} |X(j)| >= 0.85 * Σ_j |X(j)|
#
# ── Spectral Entropy ──────────────────────────────────
#   Power spectrum treated as a probability distribution.
#   P(k)  = |X(k)|^2 / Σ_k |X(k)|^2        (normalised PSD)
#   SE    = -Σ_k P(k) * log2( P(k) + ε )   (bits)
#   Normalised: SE_norm = SE / log2(N_bins)  ∈ [0, 1]
#     → 0 : energy concentrated in one bin (tonal / clean)
#     → 1 : energy spread uniformly (noise-like / reverberant)
#
# ── Spectral Flatness ─────────────────────────────────
#   Ratio of geometric mean to arithmetic mean of |X(k)|^2.
#   SF = geometric_mean(|X(k)|^2) / arithmetic_mean(|X(k)|^2)
#      = exp( mean(log(|X(k)|^2 + ε)) ) / mean(|X(k)|^2)
#   SF ∈ [0, 1]
#     → 0 : tonal / sparse spectrum (clean speech)
#     → 1 : flat / noise-like spectrum (reverberant)
#
#   Both SE and SF use |X(k)|^2 (power), ε=1e-12 for log safety.
#   ALL features computed on 1-bit QUANTIZED signal.
# ════════════════════════════════════════════════════════

N_AC_LAGS   = 3
N_FEATURES  = 6     # [ZCR, mean_AC, SC, SRO, Spec_Entropy, Spec_Flatness]

ROLLOFF_PERCENT = 0.85
LOG_EPS         = 1e-12        # guard against log(0)


def compute_zcr(signal):
    signs = np.sign(signal)
    signs[signs == 0] = 1
    return float(np.sum(np.diff(signs) != 0) / (len(signal) - 1))


def compute_mean_autocorr(signal, n_lags=N_AC_LAGS):
    signal = np.asarray(signal, dtype=np.float64)
    energy = np.sum(signal ** 2)
    if energy == 0.0:
        return 0.0
    ac = np.array(
        [np.sum(signal[:-k] * signal[k:]) / energy
         for k in range(1, n_lags + 1)]
    )
    return float(np.mean(ac))


def compute_spectral_centroid(signal, sr):
    """
    Spectral Centroid computed from FFT magnitude spectrum.
      Centroid = Σ_k [ f_k * |X(k)| ] / Σ_k |X(k)|
    Returns centroid frequency in Hz.
    Returns 0.0 on zero-energy signal.
    """
    signal    = np.asarray(signal, dtype=np.float64)
    N         = len(signal)
    mag       = np.abs(np.fft.rfft(signal))
    total_mag = np.sum(mag)
    if total_mag == 0.0:
        return 0.0
    freqs    = np.fft.rfftfreq(N, d=1.0 / sr)
    centroid = float(np.sum(freqs * mag) / total_mag)
    return centroid


def compute_spectral_rolloff(signal, sr, roll_percent=ROLLOFF_PERCENT):
    """
    Spectral Roll-off: frequency below which `roll_percent` of the
    cumulative spectral magnitude is contained.
      Rolloff = f_k  where  Σ_{j<=k} |X(j)| >= roll_percent * Σ_j |X(j)|
    Returns rolloff frequency in Hz.
    Returns 0.0 on zero-energy signal.
    """
    signal    = np.asarray(signal, dtype=np.float64)
    N         = len(signal)
    mag       = np.abs(np.fft.rfft(signal))
    total_mag = np.sum(mag)
    if total_mag == 0.0:
        return 0.0
    freqs       = np.fft.rfftfreq(N, d=1.0 / sr)
    cum_mag     = np.cumsum(mag)
    threshold   = roll_percent * total_mag
    rolloff_idx = np.searchsorted(cum_mag, threshold)
    rolloff_idx = min(rolloff_idx, len(freqs) - 1)
    return float(freqs[rolloff_idx])


def compute_spectral_entropy(signal):
    """
    Normalised Spectral Entropy (power-spectrum based).
      P(k)    = |X(k)|^2 / Σ_k |X(k)|^2        (normalised PSD)
      SE      = -Σ_k P(k) * log2( P(k) + ε )
      SE_norm = SE / log2(N_bins)                ∈ [0, 1]
    Returns 0.0 on zero-energy signal.
    Low  → tonal / spectrally sparse  (typical of clean speech)
    High → noise-like / diffuse       (typical of reverberation)
    """
    signal    = np.asarray(signal, dtype=np.float64)
    power     = np.abs(np.fft.rfft(signal)) ** 2
    total_pwr = np.sum(power)
    if total_pwr == 0.0:
        return 0.0
    P       = power / total_pwr                            # normalised PSD
    n_bins  = len(P)
    entropy = -np.sum(P * np.log2(P + LOG_EPS))           # raw entropy (bits)
    return float(entropy / np.log2(n_bins))                # normalised ∈ [0,1]


def compute_spectral_flatness(signal):
    """
    Spectral Flatness (Wiener entropy) on power spectrum.
      SF = exp( mean(log(|X(k)|^2 + ε)) ) / mean(|X(k)|^2)
    SF ∈ [0, 1].
    Returns 0.0 on zero-energy signal.
    Low  → tonal / peaked spectrum    (typical of clean speech)
    High → flat  / noise-like         (typical of reverberation)
    """
    signal    = np.asarray(signal, dtype=np.float64)
    power     = np.abs(np.fft.rfft(signal)) ** 2
    total_pwr = np.sum(power)
    if total_pwr == 0.0:
        return 0.0
    arith_mean = np.mean(power)
    geom_mean  = np.exp(np.mean(np.log(power + LOG_EPS)))
    return float(geom_mean / (arith_mean + LOG_EPS))


def compute_features(signal_q, sr):
    zcr      = compute_zcr(signal_q)
    mean_ac  = compute_mean_autocorr(signal_q, N_AC_LAGS)
    sc       = compute_spectral_centroid(signal_q, sr)
    sro      = compute_spectral_rolloff(signal_q, sr, ROLLOFF_PERCENT)
    se       = compute_spectral_entropy(signal_q)
    sf       = compute_spectral_flatness(signal_q)
    return np.array([zcr, mean_ac, sc, sro, se, sf], dtype=np.float64)


