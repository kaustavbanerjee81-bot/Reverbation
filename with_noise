    print(f"   {os.path.basename(f)}")


def _match_length(noise, length):
    """
    Trim or tile `noise` so its length equals `length`.
    """
    n = len(noise)
    if n >= length:
        start = np.random.randint(0, n - length + 1)
        return noise[start : start + length]
    repeats = int(np.ceil(length / n))
    return np.tile(noise, repeats)[:length]


def add_noise(clean_raw, reverb_raw, rng_seed):
    """
    Randomly pick one NoiseX file, scale it to a random SNR,
    and add the SAME noise realisation to both clean and reverb signals.

    Parameters
    ----------
    clean_raw  : 1-D float64 array  — dry (room-simulated clean) speech
    reverb_raw : 1-D float64 array  — reverberant speech (same length)
    rng_seed   : int                — reproducible seed for this utterance

    Returns
    -------
    clean_noisy  : noisy clean signal
    reverb_noisy : noisy reverberant signal
    chosen_noise : basename of the selected noise file
    snr_db       : SNR actually applied (dB)
    """
    np.random.seed(rng_seed)

    # Step 1 — randomly choose one noise file
    noise_path   = _NOISE_FILES[np.random.randint(len(_NOISE_FILES))]
    noise_signal, _ = librosa.load(noise_path, sr=SR, mono=True)
    noise_signal = noise_signal.astype(np.float64)

    # Step 2 — match noise length to speech length
    length       = len(clean_raw)
    noise_matched = _match_length(noise_signal, length)

    # Step 3 — randomly choose SNR
    snr_db = np.random.uniform(SNR_MIN, SNR_MAX)

    # Step 4 — compute powers (SNR anchored to clean speech)
    speech_power = np.mean(clean_raw ** 2)
    noise_power  = np.mean(noise_matched ** 2)

    if noise_power < 1e-12 or speech_power < 1e-12:
        # silent signal / silent noise — return as-is
        return clean_raw.copy(), reverb_raw.copy(), os.path.basename(noise_path), snr_db

    # Step 5 — scale noise to desired SNR
    desired_noise_power = speech_power / (10 ** (snr_db / 10))
    scale_factor        = np.sqrt(desired_noise_power / (noise_power + 1e-10))
    scaled_noise        = noise_matched * scale_factor

    # Step 6 — add SAME scaled noise to both signals
    clean_noisy  = clean_raw  + scaled_noise
    reverb_noisy = reverb_raw + scaled_noise

    return clean_noisy, reverb_noisy, os.path.basename(noise_path), snr_db

